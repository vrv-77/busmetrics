APP_NAME=BusMetric Fuel API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.onrender\.com$
CORS_EXTRA_ORIGINS=
AUTO_INIT_DB=true
FAIL_ON_STARTUP_DB_ERROR=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=fuel-files
TIMEZONE=America/Santiago
MAX_UPLOAD_SIZE_MB=50
BATCH_INSERT_SIZE=3000
LITROS_MIN_VALIDOS=5
LITROS_MAX_VALIDOS=550
VARIACION_CONSUMO_PCT_ALERTA=0.35
AUTH_REQUIRED=false
